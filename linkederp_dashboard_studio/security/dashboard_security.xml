<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_linkederp_analytics" model="ir.module.category">
        <field name="name">LinkedERP Analytics</field>
        <field name="description">Access to LinkedERP dashboard configuration.</field>
        <field name="sequence">30</field>
    </record>

    <record id="privilege_linkederp_analytics" model="res.groups.privilege">
        <field name="name">LinkedERP Analytics</field>
        <field name="category_id" ref="module_category_linkederp_analytics"/>
        <field name="sequence">30</field>
    </record>

    <record id="group_dashboard_viewer" model="res.groups">
        <field name="name">Dashboard Viewer</field>
        <field name="privilege_id" ref="privilege_linkederp_analytics"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_dashboard_studio_manager" model="res.groups">
        <field name="name">Dashboard Manager</field>
        <field name="privilege_id" ref="privilege_linkederp_analytics"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_dashboard_viewer'))]"/>
    </record>

    <record id="privilege_dashboard_bucket_sales" model="res.groups.privilege">
        <field name="name">Dashboards: Sales</field>
        <field name="category_id" ref="module_category_linkederp_analytics"/>
        <field name="sequence">31</field>
    </record>
    <record id="group_dashboard_bucket_sales" model="res.groups">
        <field name="name">Sales Dashboards</field>
        <field name="privilege_id" ref="privilege_dashboard_bucket_sales"/>
        <field name="implied_ids" eval="[(4, ref('group_dashboard_viewer'))]"/>
    </record>

    <record id="privilege_dashboard_bucket_ops" model="res.groups.privilege">
        <field name="name">Dashboards: Ops</field>
        <field name="category_id" ref="module_category_linkederp_analytics"/>
        <field name="sequence">32</field>
    </record>
    <record id="group_dashboard_bucket_ops" model="res.groups">
        <field name="name">Ops Dashboards</field>
        <field name="privilege_id" ref="privilege_dashboard_bucket_ops"/>
        <field name="implied_ids" eval="[(4, ref('group_dashboard_viewer'))]"/>
    </record>

    <record id="privilege_dashboard_bucket_finance" model="res.groups.privilege">
        <field name="name">Dashboards: Finance</field>
        <field name="category_id" ref="module_category_linkederp_analytics"/>
        <field name="sequence">33</field>
    </record>
    <record id="group_dashboard_bucket_finance" model="res.groups">
        <field name="name">Finance Dashboards</field>
        <field name="privilege_id" ref="privilege_dashboard_bucket_finance"/>
        <field name="implied_ids" eval="[(4, ref('group_dashboard_viewer'))]"/>
    </record>

    <record id="privilege_dashboard_bucket_hr" model="res.groups.privilege">
        <field name="name">Dashboards: HR</field>
        <field name="category_id" ref="module_category_linkederp_analytics"/>
        <field name="sequence">34</field>
    </record>
    <record id="group_dashboard_bucket_hr" model="res.groups">
        <field name="name">HR Dashboards</field>
        <field name="privilege_id" ref="privilege_dashboard_bucket_hr"/>
        <field name="implied_ids" eval="[(4, ref('group_dashboard_viewer'))]"/>
    </record>

    <record id="privilege_dashboard_bucket_management" model="res.groups.privilege">
        <field name="name">Dashboards: Management</field>
        <field name="category_id" ref="module_category_linkederp_analytics"/>
        <field name="sequence">35</field>
    </record>
    <record id="group_dashboard_bucket_management" model="res.groups">
        <field name="name">Management Dashboards</field>
        <field name="privilege_id" ref="privilege_dashboard_bucket_management"/>
