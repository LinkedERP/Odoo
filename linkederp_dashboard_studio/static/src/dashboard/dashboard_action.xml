<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="linkederp_dashboard_studio.DashboardAction">
        <div class="o_linkederp_dashboard">
            <div class="o_lds_toolbar">
                <div class="o_lds_title_block">
                    <h1 t-if="state.dashboard" t-esc="state.dashboard.name"/>
                    <h1 t-else="">Dashboard Studio</h1>
                    <p t-if="state.dashboard &amp;&amp; state.dashboard.description" t-esc="state.dashboard.description"/>
                </div>
                <div class="o_lds_controls">
                    <select class="form-select" t-on-change="onDashboardChange">
                        <t t-foreach="state.dashboards" t-as="dashboard" t-key="dashboard.id">
                            <option
                                t-att-value="dashboard.id"
                                t-att-selected="state.dashboard &amp;&amp; dashboard.id === state.dashboard.id">
                                <t t-esc="dashboard.name"/>
                            </option>
                        </t>
                    </select>
                    <select
                        t-if="state.crmFilters.enabled"
                        class="form-select o_lds_filter_select"
                        t-on-change="(ev) => setFilter('campaignId', ev.target.value)">
                        <option value="">All campaigns</option>
                        <t t-foreach="state.crmFilters.campaigns" t-as="option" t-key="option.id">
                            <option
                                t-att-value="option.id"
                                t-att-selected="isFilterSelected('campaignId', option.id)"
                                t-esc="optionLabel(option)"/>
                        </t>
                    </select>
                    <select
                        t-if="state.crmFilters.enabled"
                        class="form-select o_lds_filter_select"
                        t-on-change="(ev) => setFilter('userId', ev.target.value)">
                        <option value="">All salespeople</option>
                        <t t-foreach="state.crmFilters.salespeople" t-as="option" t-key="option.id">
                            <option
                                t-att-value="option.id"
                                t-att-selected="isFilterSelected('userId', option.id)"
                                t-esc="optionLabel(option)"/>
                        </t>
                    </select>
                    <select
                        t-if="state.crmFilters.enabled"
                        class="form-select o_lds_filter_select"
                        t-on-change="(ev) => setFilter('teamId', ev.target.value)">
                        <option value="">All teams</option>
                        <t t-foreach="state.crmFilters.teams" t-as="option" t-key="option.id">
                            <option
                                t-att-value="option.id"
                                t-att-selected="isFilterSelected('teamId', option.id)"
                                t-esc="optionLabel(option)"/>
                        </t>
                    </select>
                    <select
                        t-if="state.crmFilters.enabled"
                        class="form-select o_lds_filter_select"
                        t-on-change="(ev) => setFilter('stageId', ev.target.value)">
                        <option value="">All stages</option>
                        <t t-foreach="state.crmFilters.stages" t-as="option" t-key="option.id">
                            <option
                                t-att-value="option.id"
                                t-att-selected="isFilterSelected('stageId', option.id)"
                                t-esc="optionLabel(option)"/>
                        </t>
                    </select>
                    <select
                        t-if="state.opsFilters.enabled"
                        class="form-select o_lds_filter_select"
                        t-on-change="onWeekChange">
                        <t t-foreach="state.opsFilters.weeks" t-as="option" t-key="option.value">
                            <option
                                t-att-value="option.value"
                                t-att-selected="isWeekSelected(option.value)"
                                t-esc="option.label"/>
                        </t>
                    </select>
                    <select
                        t-if="state.opsFilters.enabled &amp;&amp; state.opsFilters.teams"
                        class="form-select o_lds_filter_select"
                        t-on-change="onOpsTeamChange">
                        <t t-foreach="state.opsFilters.teams" t-as="option" t-key="option.value">
                            <option
                                t-att-value="option.value"
                                t-att-selected="isOpsTeamSelected(option.value)"
                                t-esc="option.label"/>
                        </t>
                    </select>
                    <input t-if="!state.opsFilters.enabled" class="form-control" type="date" t-model="state.filters.dateFrom"/>
                    <input t-if="!state.opsFilters.enabled" class="form-control" type="date" t-model="state.filters.dateTo"/>
                    <button class="btn btn-primary" type="button" t-on-click="applyFilters" title="Apply filters">
                        <i class="fa fa-filter"/>
                    </button>
                    <button class="btn btn-outline-secondary" type="button" t-on-click="resetFilters" title="Reset filters">
                        <i class="fa fa-refresh"/>
                    </button>
                </div>
            </div>

            <div t-if="state.loading" class="o_lds_empty">
                <i class="fa fa-spinner fa-spin"/>
                <span>Loading dashboard</span>
            </div>

            <div t-elif="!state.dashboard" class="o_lds_empty">
                <i class="fa fa-bar-chart"/>
                <span>No dashboard is configured yet.</span>
            </div>

            <div t-else="" class="o_lds_grid">
                <t t-foreach="state.widgets" t-as="widget" t-key="widget.id">
                    <section
                        t-att-class="'o_lds_widget o_lds_widget_' + widget.type + (widget.span ? ' o_lds_span_' + widget.span : '')"
                        t-att-style="'--lds-accent:' + (widget.color || '#2563eb')">
                        <header t-if="widget.type !== 'trendline'" class="o_lds_widget_header">
                            <div>
                                <h2 t-esc="widget.name"/>
                                <span t-if="widget.help" t-esc="widget.help"/>
                            </div>
                            <div class="o_lds_widget_header_aside">
                                <span
                                    t-if="widget.badge"
                                    t-att-class="'o_lds_badge ' + (widget.value >= (widget.target || 0) ? 'o_lds_tone_good' : 'o_lds_tone_bad')"
                                    t-esc="widget.badge"/>
                                <button
                                    class="btn btn-sm btn-link"
                                    type="button"
                                    t-on-click="() => openRecords(widget.model, widget.domain)"
                                    title="Open records">
                                    <i class="fa fa-external-link"/>
                                </button>
                            </div>
                        </header>

                        <div t-if="widget.error" class="o_lds_widget_error">
                            <i class="fa fa-warning"/>
                            <span t-esc="widget.error"/>
                        </div>

                        <t t-elif="widget.type === 'kpi'">
                            <button
                                class="o_lds_kpi"
                                type="button"
                                t-on-click="() => openRecords(widget.model, widget.domain)">
                                <span class="o_lds_kpi_value" t-esc="formatWidgetValue(widget)"/>
                                <span class="o_lds_kpi_caption" t-esc="widget.measure"/>
                            </button>
                        </t>

                        <t t-elif="widget.type === 'trendline'">
                            <button
                                class="o_lds_trend"
                                type="button"
                                t-on-click="() => openRecords(widget.model, widget.domain)">
                                <svg class="o_lds_trend_svg" viewBox="0 0 300 100" preserveAspectRatio="none" role="img">
                                    <polyline class="o_lds_trend_line" t-att-points="trendLinePoints(widget)"/>
                                    <t t-foreach="trendMarkers(widget)" t-as="m" t-key="m_index">
                                        <circle t-att-cx="m.x" t-att-cy="m.y" r="3.5" t-att-fill="m.color"/>
                                    </t>
                                </svg>
                                <div class="o_lds_trend_labels">
                                    <t t-foreach="widget.points" t-as="point" t-key="point.label">
                                        <span t-esc="point.label"/>
                                    </t>
                                </div>
                            </button>
                        </t>

                        <t t-elif="widget.type === 'bar'">
                            <div class="o_lds_bars">
                                <t t-foreach="widget.points" t-as="point" t-key="point.label">
                                    <button
                                        class="o_lds_bar_row"
                                        type="button"
                                        t-on-click="() => openRecords(widget.model, point.domain)">
                                        <span class="o_lds_bar_label" t-esc="point.label"/>
                                        <span class="o_lds_bar_track">
                                            <span class="o_lds_bar_fill" t-att-style="barStyle(widget, point)"/>
                                        </span>
                                        <span class="o_lds_bar_value" t-esc="formatPointValue(widget, point.value)"/>
                                    </button>
                                </t>
                            </div>
                        </t>

                        <t t-elif="widget.type === 'comparison'">
                            <div class="o_lds_compare">
                                <div class="o_lds_compare_legend">
                                    <span><i class="o_lds_compare_generated"/>Generated</span>
                                    <span><i class="o_lds_compare_meetings"/>Meetings</span>
                                </div>
                                <t t-foreach="widget.rows" t-as="row" t-key="row.label">
                                    <div class="o_lds_compare_row">
                                        <button
                                            class="o_lds_compare_label"
                                            type="button"
                                            t-on-click="() => openRecords(widget.model, row.domain)">
                                            <span t-esc="row.label"/>
                                            <strong t-esc="formatByType(row.meeting_rate, 'percent')"/>
                                        </button>
                                        <div class="o_lds_compare_tracks">
                                            <button
                                                class="o_lds_compare_track"
                                                type="button"
                                                t-on-click="() => openRecords(widget.model, row.domain)">
                                                <span class="o_lds_compare_fill" t-att-style="comparisonBarStyle(widget, row, 'generated')"/>
                                                <strong t-esc="formatByType(row.generated, 'integer')"/>
                                            </button>
                                            <button
                                                class="o_lds_compare_track"
                                                type="button"
                                                t-on-click="() => openRecords(widget.model, row.meetings_domain)">
                                                <span class="o_lds_compare_fill" t-att-style="comparisonBarStyle(widget, row, 'meetings')"/>
                                                <strong t-esc="formatByType(row.meetings, 'integer')"/>
                                            </button>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>

                        <t t-elif="widget.type === 'column'">
                            <div class="o_lds_columns">
                                <div class="o_lds_column_axis">
                                    <t t-foreach="columnGridLines(widget)" t-as="line" t-key="line_index">
                                        <span t-esc="formatPointValue(widget, line)"/>
                                    </t>
                                </div>
                                <div class="o_lds_column_plot">
                                    <span
                                        t-if="widget.target"
                                        class="o_lds_column_target"
                                        t-att-style="columnTargetStyle(widget)"/>
                                    <t t-foreach="widget.points" t-as="point" t-key="point.label">
                                        <button
                                            class="o_lds_column_item"
                                            type="button"
                                            t-att-title="point.label + ': ' + formatPointValue(widget, point.value)"
                                            t-on-click="() => openRecords(widget.model, point.domain)">
                                            <span class="o_lds_column_bar_wrap">
                                                <span class="o_lds_column_bar" t-att-style="columnStyle(widget, point, point_index)">
                                                    <strong t-esc="formatPointValue(widget, point.value)"/>
                                                </span>
                                            </span>
                                            <span class="o_lds_column_label" t-esc="point.label"/>
                                        </button>
                                    </t>
                                </div>
                            </div>
                        </t>

                        <t t-elif="widget.type === 'stacked'">
                            <div class="o_lds_stack">
                                <button
                                    class="o_lds_stack_bar"
                                    type="button"
                                    t-on-click="() => openRecords(widget.model, widget.domain)">
                                    <t t-foreach="widget.points" t-as="point" t-key="point.label">
                                        <span
                                            class="o_lds_stack_segment"
                                            t-att-title="point.label"
                                            t-att-style="stackSegmentStyle(widget, point, point_index)">
                                            <strong t-esc="formatPointValue(widget, point.value)"/>
                                        </span>
                                    </t>
                                </button>
                                <div class="o_lds_stack_legend">
                                    <t t-foreach="widget.points" t-as="point" t-key="point.label">
                                        <button type="button" t-on-click="() => openRecords(widget.model, point.domain)">
                                            <i t-att-style="legendColor(point_index)"/>
                                            <span t-esc="point.label"/>
                                            <strong t-esc="formatPointValue(widget, point.value)"/>
                                        </button>
                                    </t>
                                </div>
                            </div>
                        </t>

                        <t t-elif="widget.type === 'gauge'">
                            <button
                                class="o_lds_gauge"
                                type="button"
                                t-on-click="() => openRecords(widget.model, widget.domain)">
                                <span class="o_lds_gauge_ring" t-att-style="gaugeStyle(widget)">
                                    <span>
                                        <strong t-esc="formatWidgetValue(widget)"/>
                                        <small t-esc="widget.measure"/>
                                    </span>
                                </span>
                            </button>
                        </t>

                        <t t-elif="widget.type === 'funnel'">
                            <div class="o_lds_funnel">
                                <t t-foreach="widget.points" t-as="point" t-key="point.label">
                                    <button
                                        class="o_lds_funnel_row"
                                        type="button"
                                        t-on-click="() => openRecords(widget.model, point.domain)">
                                        <span class="o_lds_funnel_label" t-esc="point.label"/>
                                        <span class="o_lds_funnel_track">
                                            <span class="o_lds_funnel_fill" t-att-style="funnelStyle(widget, point)">
                                                <strong t-esc="formatPointValue(widget, point.value)"/>
                                            </span>
                                        </span>
                                        <span class="o_lds_funnel_share" t-esc="pointShare(widget, point)"/>
                                    </button>
                                </t>
                            </div>
                        </t>

                        <t t-elif="widget.type === 'line'">
                            <button
                                class="o_lds_line"
                                type="button"
                                t-on-click="() => openRecords(widget.model, widget.domain)">
                                <svg viewBox="0 0 300 110" preserveAspectRatio="none" role="img">
                                    <polyline class="o_lds_line_area" t-att-points="linePoints(widget)"/>
                                    <polyline class="o_lds_line_stroke" t-att-points="linePoints(widget)"/>
                                </svg>
                                <div class="o_lds_line_ticks" t-if="widget.points.length">
                                    <t t-foreach="widget.points" t-as="point" t-key="point.label">
                                        <span>
                                            <small t-esc="point.label"/>
                                            <strong t-esc="formatPointValue(widget, point.value)"/>
                                        </span>
                                    </t>
                                </div>
                                <div class="o_lds_axis">
                                    <span t-if="widget.points.length" t-esc="widget.points[0].label"/>
                                    <strong t-esc="formatWidgetValue(widget)"/>
                                    <span t-if="widget.points.length" t-esc="widget.points[widget.points.length - 1].label"/>
                                </div>
                            </button>
                        </t>

                        <t t-elif="widget.type === 'pie' || widget.type === 'donut'">
                            <div class="o_lds_pie_wrap">
                                <button
                                    class="o_lds_pie"
                                    type="button"
                                    t-att-style="pieStyle(widget)"
                                    t-on-click="() => openRecords(widget.model, widget.domain)">
                                    <span t-esc="formatWidgetValue(widget)"/>
                                </button>
                                <div class="o_lds_legend">
                                    <t t-foreach="widget.points" t-as="point" t-key="point.label">
                                        <button type="button" t-on-click="() => openRecords(widget.model, point.domain)">
                                            <i t-att-style="legendColor(point_index)"/>
                                            <span t-esc="point.label"/>
                                            <strong t-esc="formatPointValue(widget, point.value)"/>
                                        </button>
                                    </t>
                                </div>
                            </div>
                        </t>

                        <t t-elif="widget.type === 'matrix'">
                            <div class="o_lds_matrix_wrap">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th class="text-start" t-esc="widget.groupby"/>
                                            <t t-foreach="widget.columns" t-as="column" t-key="column.key">
                                                <th class="text-center" t-esc="column.label"/>
                                            </t>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="widget.rows" t-as="row" t-key="row.label">
                                            <tr t-on-click="() => openRecords(widget.model, row.domain)">
                                                <td class="text-start" t-esc="row.label"/>
                                                <t t-foreach="widget.columns" t-as="column" t-key="column.key">
                                                    <td class="text-center" t-esc="matrixCellValue(row, column)"/>
                                                </t>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <t t-elif="widget.type === 'table'">
                            <div class="o_lds_table_wrap">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th t-esc="widget.groupby"/>
                                            <th class="text-end" t-esc="widget.measure"/>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="widget.points" t-as="point" t-key="point.label">
                                            <tr t-on-click="() => openRecords(widget.model, point.domain)">
                                                <td t-esc="point.label"/>
                                                <td class="text-end" t-esc="formatPointValue(widget, point.value)"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </section>
                </t>
            </div>
        </div>
    </t>
</templates>
