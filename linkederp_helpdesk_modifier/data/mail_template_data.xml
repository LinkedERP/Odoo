<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">
    <record id="helpdesk_ticket_reminder_template" model="mail.template">
        <field name="name">Helpdesk: Unanswered Ticket Reminder</field>
        <field name="model_id" ref="helpdesk.model_helpdesk_ticket"/>
        <field name="subject">Reminder For: Ticket #{{ object.ticket_ref }} – {{ object.name }} has not been responded to</field>
        <field name="email_from">{{ object.company_id.email_formatted or user.email_formatted }}</field>
        <field name="email_to"/>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333;">
                <p>Dear Support Team,</p>
                <p>
                    This is an automated reminder that the following helpdesk ticket has
                    <strong>not received a response for more than 3 days</strong> and requires your attention:
                </p>
                <table style="border-collapse: collapse; width: 100%; margin: 16px 0;">
                    <tr>
                        <td style="padding: 8px 12px; background: #f5f5f5; font-weight: bold; width: 180px;">Ticket
                            Reference</td>
                        <td style="padding: 8px 12px; border-bottom: 1px solid #e0e0e0;"><t
                                t-out="object.ticket_ref or object.id"/></td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 12px; background: #f5f5f5; font-weight: bold;">Ticket Name</td>
                        <td style="padding: 8px 12px; border-bottom: 1px solid #e0e0e0;"><t t-out="object.name"/></td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 12px; background: #f5f5f5; font-weight: bold;">Customer</td>
                        <td style="padding: 8px 12px; border-bottom: 1px solid #e0e0e0;"><t
                                t-out="object.partner_id.name or object.partner_name or '-'"/></td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 12px; background: #f5f5f5; font-weight: bold;">Helpdesk Team</td>
                        <td style="padding: 8px 12px; border-bottom: 1px solid #e0e0e0;"><t
                                t-out="object.team_id.name"/></td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 12px; background: #f5f5f5; font-weight: bold;">Assigned To</td>
                        <td style="padding: 8px 12px; border-bottom: 1px solid #e0e0e0;"><t
                                t-out="object.user_id.name or 'Unassigned'"/></td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 12px; background: #f5f5f5; font-weight: bold;">Current Stage</td>
                        <td style="padding: 8px 12px; border-bottom: 1px solid #e0e0e0;"><t
                                t-out="object.stage_id.name"/></td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 12px; background: #f5f5f5; font-weight: bold;">Created On</td>
                        <td style="padding: 8px 12px; border-bottom: 1px solid #e0e0e0;"><t
                                t-out="object.create_date.strftime('%d %B %Y') if object.create_date else '-'"/></td>
                    </tr>
                </table>
                <p>
                    Please follow up with the customer as soon as possible.
                </p>
                <div style="text-align: center; margin: 24px 0;">
                    <a t-attf-href="#{object.get_base_url()}/odoo/helpdesk/#{object.team_id.id}/tickets/#{object.id}"
                       style="background-color: #875A7B; padding: 10px 20px; text-decoration: none;
                  color: #ffffff; border-radius: 5px; font-size: 13px;">
                        View Ticket
                    </a>
                </div>
                <p style="color: #888; font-size: 12px;">
                    This is an automated reminder generated by LinkedERP. Please do not reply to this email directly.
                </p>
            </div>
        </field>
        <field name="lang">{{ object.user_id.lang or user.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>
