<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Project Manager field to the Helpdesk Team form view -->
    <record id="helpdesk_team_view_form_linked" model="ir.ui.view">
        <field name="name">helpdesk.team.form.linked</field>
        <field name="model">helpdesk.team</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_team_view_form"/>
        <field name="arch" type="xml">
            <!-- Insert Project Manager field after the team name field -->
            <field name="name" position="after">
                <field name="project_manager_id"
                       placeholder="Select a project manager..."
                       options="{'no_create': True}"/>
            </field>
            <xpath expr="//setting[@id='timesheet']" position='inside'>
                <div invisible="not use_helpdesk_timesheet">
                    <label for="project_task_id" string="Task"/>
                    <field name="project_task_id" class="oe_inline"
                           context="{'default_allow_billable': use_helpdesk_sale_timesheet, 'default_use_documents': False}"/>
                </div>
            </xpath>
        </field>
    </record>
    

    <!-- A05: roll-up task on the ticket (defaults from team, editable) -->
    <record id="helpdesk_ticket_view_form_task_link" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.task.linked</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <field name="user_id" position="after">
                <field name="task_id" options="{'no_create': True}"/>
            </field>
        </field>
    </record>

    <!-- Restrict sale_line_id on ticket to the SO linked via team → project → SO -->
    <record id="helpdesk_ticket_view_form_sale_line" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.sale.line.linked</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_sale.helpdesk_ticket_view_form_inherit_helpdesk_invoicing"/>
        <field name="arch" type="xml">
            <field name="sale_order_id" position="before">
                <field name="available_sale_line_domain" invisible="1"/>
                <field name="team_project_id" invisible="1"/>
            </field>
        </field>
    </record>
</odoo>
