<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sales_order_search_unlocked" model="ir.ui.view">
        <field name="name">sale.order.search.linked.unlocked</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="arch" type="xml">
            <filter name="sales" position="after">
                <separator/>
                <filter name="sale_complete" position="after">
                    <separator/>
                    <filter
                            name="not_completed"
                            string="Uncompleted Orders"
                            domain="[('x_studio_completed', '=', False)]"
                            help="Show only Uncompleted  Sales Orders"/>

                    <filter
                            name="completed"
                            string="Complete Order"
                            domain="[('x_studio_completed', '=', True)]"
                            help="Show only Complete Sales Orders"/>
                </filter>

            </filter>
        </field>
    </record>

    <record id="sale_order_view_search_inherit_quotation_lock" model="ir.ui.view">
        <field name="name">sale.order.search.linked.unlocked</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_quotation"/>
        <field name="arch" type="xml">
            <filter name="my_quotation" position="after">
                <separator/>
                <filter name="quotation_complete" position="after">
                    <separator/>
                    <filter
                            name="quotation_not_completed"
                            string="Uncompleted Orders"
                            domain="[('x_studio_completed', '=', False)]"
                            help="Show only Uncompleted  Sales Orders"/>

                    <filter
                            name="quotation_completed"
                            string="Complete Order"
                            domain="[('x_studio_completed', '=', True)]"
                            help="Show only Complete Sales Orders"/>
                </filter>
            </filter>
        </field>
    </record>


    <!--
        Set "Active Orders (Unlocked)" as the default filter on the
        Sales Orders window action.
        Using 'context' with default filter instead of 'domain' allows users
        to override the filter and see locked orders when needed.
    -->
    <record id="sale.action_orders" model="ir.actions.act_window">
        <field name="context">{'search_default_not_completed': 1, 'search_default_sales': 1}</field>
    </record>
    <record id="sale.action_quotations_with_onboarding" model="ir.actions.act_window">
        <field name="context">{'search_default_quotation_not_completed': 1, 'search_default_my_quotation': 1}</field>
    </record>
</odoo>
