<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
      Odoo 19 security model: groups are grouped under a res.groups.privilege
      (which in turn references an ir.module.category). The old res.groups.category_id
      was removed in 19 - groups now use privilege_id.
    -->
    <record id="module_category_mrelate_tds" model="ir.module.category">
        <field name="name">India Payroll TDS</field>
        <field name="sequence">20</field>
    </record>

    <record id="privilege_mrelate_tds" model="res.groups.privilege">
        <field name="name">India Payroll TDS</field>
        <field name="category_id" ref="module_category_mrelate_tds"/>
        <field name="sequence">20</field>
    </record>

    <record id="group_tds_employee" model="res.groups">
        <field name="name">TDS: Employee (own declarations)</field>
        <field name="privilege_id" ref="privilege_mrelate_tds"/>
    </record>

    <record id="group_tds_reviewer" model="res.groups">
        <field name="name">TDS: Payroll Reviewer</field>
        <field name="privilege_id" ref="privilege_mrelate_tds"/>
        <field name="implied_ids" eval="[(4, ref('group_tds_employee'))]"/>
    </record>

    <!-- Employees see only their own declarations -->
    <record id="rule_tds_declaration_own" model="ir.rule">
        <field name="name">TDS declaration: own only</field>
        <field name="model_id" ref="model_mrelate_tds_declaration"/>
        <field name="domain_force">
            ['|', ('employee_id.user_id', '=', user.id), ('create_uid', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('group_tds_employee'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Reviewers see everything -->
    <record id="rule_tds_declaration_all" model="ir.rule">
        <field name="name">TDS declaration: reviewer sees all</field>
        <field name="model_id" ref="model_mrelate_tds_declaration"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_tds_reviewer'))]"/>
    </record>

</odoo>
